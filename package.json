    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "framer-motion": "^10.12.16",
    "lucide-react": "^0.275.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "nodemailer": "^6.9.15"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.0.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.13"
  },
  "browserslist": {
    "production": [
      ">0.2%",
