# Save AS ".env" in the SAME folder as package.json (project root).
# Do not put secrets only in .env.example — that file is for documentation.
# The Node server does NOT read Create React App's REACT_APP_* vars for Gmail.

# Gmail address you use to send mail (must match App Password account)
GMAIL_USER=you@gmail.com

# Google App Password: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=your_16_char_app_password

# Where to receive contact form emails (defaults to GMAIL_USER)
NOTIFY_EMAIL=you@gmail.com

# Optional display From header (defaults to "Portfolio" <GMAIL_USER>)
# MAIL_FROM="Portfolio Site <you@gmail.com>"

# Comma-separated browser origins (exact URLs). Required for the contact form in production.
# Include your live site, e.g. https://your-app.up.railway.app — and keep http://localhost:3000 for local dev.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.up.railway.app

# Local API port only — do NOT set PORT here (Create React App uses PORT). Hosts like Railway set PORT automatically.
CONTACT_API_PORT=5001

# --- Deploy (Railway / Render / similar) ---
# 1) Push this repo to GitHub (never commit .env).
# 2) New project → Deploy from GitHub → pick this repo.
# 3) Build: npm run build   Start: npm run serve   (see railway.toml for Railway.)
# 4) In the host dashboard, add env vars: GMAIL_USER, GMAIL_APP_PASSWORD, NOTIFY_EMAIL,
#    and ALLOWED_ORIGINS including your real https://... public URL (comma-separated).
# 5) After first deploy, copy the public URL into ALLOWED_ORIGINS and redeploy if the form was blocked by CORS.
